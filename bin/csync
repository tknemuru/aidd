#!/usr/bin/env bash
set -euo pipefail

# スクリプト自身の位置から aidd リポジトリのルートを特定する。
# シンボリックリンク経由の起動（~/.local/bin/csync 等）にも対応する。
AIDD_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
SOURCE_DIR="$AIDD_ROOT/adapters/claude"

# Git リポジトリのルートを取得
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "エラー: gitリポジトリ内で実行してください。" >&2
  exit 1
}

# aidd 自身への同期を防止
if [ "$REPO_ROOT" = "$AIDD_ROOT" ]; then
  echo "エラー: aidd リポジトリ自身には同期できません。" >&2
  exit 1
fi

DEST_CLAUDE_DIR="$REPO_ROOT/.claude"

echo "同期元: $SOURCE_DIR"
echo "同期先: $REPO_ROOT"
echo ""

# .claude ディレクトリ配下にコピー（CLAUDE.md を除く）
mkdir -p "$DEST_CLAUDE_DIR"
rsync -av --exclude='CLAUDE.md' --exclude='settings.local.json' "$SOURCE_DIR/" "$DEST_CLAUDE_DIR/"

# CLAUDE.md はリポジトリルート直下にコピー
cp "$SOURCE_DIR/CLAUDE.md" "$REPO_ROOT/CLAUDE.md"

echo ""
echo "完了: Claude設定を $REPO_ROOT に同期しました。"
